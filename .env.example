# =============================================================
# AedtCopilot 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# 注意: .env 文件不应提交到 git（已在 .gitignore 中排除）
# =============================================================

# ----- LLM 配置 -----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# 可选：Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ----- HFSS 配置（已确认：AEDT 19.5 = 2019 R3）-----
# HFSS 安装根目录
HFSS_INSTALL_PATH=D:\Program Files\AnsysEM\AnsysEM19.5\Win64
# HFSS 主程序
HFSS_EXECUTABLE=D:\Program Files\AnsysEM\AnsysEM19.5\Win64\ansysedt.exe
# COM ProgID（注册表已确认：HKLM\SOFTWARE\Classes\AnsoftHfss.HfssScriptInterface）
HFSS_COM_PROGID=AnsoftHfss.HfssScriptInterface
# 默认 HFSS 项目保存目录
HFSS_PROJECT_DIR=D:\Projects\HFSS

# ----- 后端服务配置 -----
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
# 允许跨域的前端地址
CORS_ORIGINS=http://localhost:3000

# ----- RAG 知识库配置 -----
CHROMADB_PATH=./data/chromadb
# HFSS Scripting Guide PDF 路径（用于构建 RAG 索引）
HFSS_DOCS_PATH=./docs/hfss_scripting_guide.pdf

# ----- 调试配置 -----
# DEBUG=true 时 Agent 会打印详细的工具调用日志
DEBUG=false
LOG_LEVEL=INFO
